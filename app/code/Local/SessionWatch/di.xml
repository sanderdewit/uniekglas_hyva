<?xml version="1.0"?>
<!-- Intercept session start across core session classes -->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <type name="Magento\Framework\Session\SessionManager">
        <plugin name="local_sessionwatch_main"
                type="Local\SessionWatch\Plugin\SessionStartWatch"
                sortOrder="1"/>
    </type>

    <type name="Magento\Framework\Session\Generic">
        <plugin name="local_sessionwatch_generic"
                type="Local\SessionWatch\Plugin\SessionStartWatch"
                sortOrder="1"/>
    </type>

    <type name="Magento\Customer\Model\Session">
        <plugin name="local_sessionwatch_customer"
                type="Local\SessionWatch\Plugin\SessionStartWatch"
                sortOrder="1"/>
    </type>

    <!-- Optional: if something type-hints the interface -->
    <type name="Magento\Framework\Session\SessionManagerInterface">
        <plugin name="local_sessionwatch_iface"
                type="Local\SessionWatch\Plugin\SessionStartWatch"
                sortOrder="1"/>
    </type>
</config>
